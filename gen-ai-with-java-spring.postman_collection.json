        {
          "name": "java-docs-gemini-vertex-ai",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "    @Override\n    @Transactional\n    public void process(PaymentResponse paymentResponse) {\n        Optional<OrderPaymentOutboxMessage> orderPaymentOutboxMessageResponse =\n                paymentOutboxHelper.getPaymentOutboxMessageBySagaIdAndSagaStatus(\n                        UUID.fromString(paymentResponse.getSagaId()),\n                        SagaStatus.STARTED);\n\n        if (orderPaymentOutboxMessageResponse.isEmpty()) {\n            log.info(\"An outbox message with saga id: {} is already processed!\", paymentResponse.getSagaId());\n            return;\n        }\n\n        OrderPaymentOutboxMessage orderPaymentOutboxMessage = orderPaymentOutboxMessageResponse.get();\n\n        OrderPaidEvent domainEvent = completePaymentForOrder(paymentResponse);\n\n        SagaStatus sagaStatus = orderSagaHelper.orderStatusToSagaStatus(domainEvent.getOrder().getOrderStatus());\n\n        paymentOutboxHelper.save(getUpdatedPaymentOutboxMessage(orderPaymentOutboxMessage,\n                domainEvent.getOrder().getOrderStatus(), sagaStatus));\n\n        approvalOutboxHelper\n                .saveApprovalOutboxMessage(orderDataMapper.orderPaidEventToOrderApprovalEventPayload(domainEvent),\n                        domainEvent.getOrder().getOrderStatus(),\n                        sagaStatus,\n                        OutboxStatus.STARTED,\n                        UUID.fromString(paymentResponse.getSagaId()));\n\n        log.info(\"Order with id: {} is paid\", domainEvent.getOrder().getId().getValue());\n    }",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "localhost:8081/api/vertexai/chat/generate-java-docs",
              "host": [
                "localhost"
              ],
              "port": "8081",
              "path": [
                "api",
                "vertexai",
                "chat",
                "generate-java-docs"
              ]
            }
          },
          "response": []
        },
